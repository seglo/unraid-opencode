<?xml version="1.0"?>
<Container version="2">
    <Name>opencode</Name>
    <Beta>false</Beta>
    <Category>Productivity: Tools: AI:</Category>
    <Repository>ghcr.io/seglo/unraid-opencode:latest</Repository>
    <Registry>https://github.com/seglo/unraid-opencode/pkgs/container/unraid-opencode</Registry>
    <Network>bridge</Network>
    <ExtraParams></ExtraParams>
    <Shell>bash</Shell>
    <GitHub>https://github.com/seglo/unraid-opencode</GitHub>
    <Project>https://opencode.ai</Project>
    <Overview>OpenCode is an AI-powered coding agent with a terminal UI and web interface. This container runs opencode web for browser-based remote access.&#13;&#13;This image extends the official opencode image with git, Node.js, Python, SSH, and other essentials for full MCP server and VCS support.&#13;&#13;Access the web UI at: http://[IP]:[PORT:4096]&#13;&#13;Docs: https://opencode.ai/docs/server</Overview>
    <WebUI>http://[IP]:[PORT:4096]</WebUI>
    <TemplateURL>https://raw.githubusercontent.com/seglo/unraid-opencode/main/templates/unraid-opencode.xml</TemplateURL>
    <Icon>https://raw.githubusercontent.com/anomalyco/opencode/dev/packages/web/src/assets/favicon.svg</Icon>
    <Date>2026-06-02</Date>
    <Changes></Changes>

    <!-- Port Mappings -->
    <Config Name="Port: Web UI" Target="4096" Default="4096" Mode="tcp" Description="HTTP port for the OpenCode web interface." Type="Port" Display="always" Required="true" Mask="false"/>

    <!-- Volume Mappings -->
    <Config Name="Path: Workspace" Target="/workspace" Default="/mnt/user/appdata/opencode/workspace" Mode="rw" Description="Main workspace directory for your projects." Type="Path" Display="always" Required="false" Mask="false"/>
    <Config Name="Path: Config File" Target="/root/.config/opencode/opencode.json" Default="/mnt/user/appdata/opencode/opencode.json" Mode="rw" Description="OpenCode configuration file (opencode.json)." Type="Path" Display="always" Required="false" Mask="false"/>
    <Config Name="Path: Auth File" Target="/root/.local/share/opencode/auth.json" Default="/mnt/user/appdata/opencode/auth.json" Mode="rw" Description="OpenCode auth file (auth.json)." Type="Path" Display="always" Required="false" Mask="false"/>

    <!-- Separator: Advanced -->
    <Config Name="--- Advanced ---" Target="" Default="" Mode="" Description="" Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="Variable: OPENCODE_CONFIG" Target="OPENCODE_CONFIG" Default="" Description="Custom path to opencode.json config file." Type="Variable" Display="advanced" Required="false" Mask="false"/>
    <Config Name="Variable: OPENCODE_CONFIG_CONTENT" Target="OPENCODE_CONFIG_CONTENT" Default="" Description="Inline JSON config content (highest precedence)." Type="Variable" Display="advanced" Required="false" Mask="false"/>
</Container>
